# 複製這個檔案為 .env 並填入你的設定

# ── LLM Provider ─────────────────────────────────────────────
# 選擇要使用的 LLM，不需要 rebuild image
# 可選值：gemini | openai | ollama（預設：gemini）
LLM_PROVIDER=gemini

# 覆蓋該 provider 的預設 model（可省略）
# gemini 預設：gemini-2.5-flash-lite
# openai 預設：gpt-5.4-mini
# ollama 預設：qwen3:14b
# LLM_MODEL=

# Google Gemini（https://aistudio.google.com/，有免費額度）
GOOGLE_API_KEY=...

# OpenAI
OPENAI_API_KEY=...

# Ollama（預設 localhost:11434，改這裡可以指向遠端機器）
OLLAMA_BASE_URL=http://localhost:11434

# Minecraft server 連線設定
MC_HOST=localhost
MC_PORT=25565
MC_USERNAME=Agent
MC_VERSION=1.20.1
MC_AUTH=offline
BOT_USERNAMES=Agent0,Agent1
STRICT_CHAT_ADDRESSING=true
